{#
    Homepage override for PlentyTestPlugin.
    Structure mirrors a typical B2B/industrial-product homepage layout
    (nav → hero carousel → quick-links grid → value prop banner →
    article/insights grid → text block with CTA → footer).

    HOW TO EDIT:
    Everything you'd want to change (nav items, hero slides, quick links,
    banner text, article cards, footer columns) is defined as a {% set %}
    variable right below this comment. Edit the arrays, not the markup
    further down, unless you want to change layout/structure.

    Image paths below are placeholders (/images/...). Point them at
    wherever this plugin's assets actually get served from in your
    PlentyONE setup (plugin asset upload / CDN) — check your platform's
    asset-referencing convention before going live.

    Design tokens (accent orange, dark slate header, ~1500px container,
    generic sans-serif) are tuned to sit close to lumi.cn's public visual
    style. Content, images, logo and copy are all placeholder — none of
    lumi.cn's actual text/photos/brand assets are used here.

    CSS/JS live in resources/css/demo-home.css and resources/js/demo-home.js
    (not inline) because PlentyONE shops typically send a Content-Security-
    Policy header that blocks inline <style>/<script>. The href/src below
    are placeholders — point them at wherever your PlentyONE instance
    actually serves this plugin's static assets (check Plugin overview →
    your plugin → asset/CDN URL, since this varies by platform version).
#}

{% set site = {
    name: 'Your Company',
    tagline: 'Replace this tagline'
} %}

{% set nav_items = [
    { label: 'About Us',    url: '/about' },
    { label: 'Products',    url: '/products' },
    { label: 'Support',     url: '/support' },
    { label: 'R&D',         url: '/rd' },
    { label: 'News',        url: '/news' },
    { label: 'Contact Us',  url: '/contact' }
] %}

{% set hero_slides = [
    {
        image: '/images/hero-1.jpg',
        title: 'Product Series One',
        subtitle: 'Short one-line description of this product line goes here.',
        link: '/products/series-one'
    },
    {
        image: '/images/hero-2.jpg',
        title: 'Product Series Two',
        subtitle: 'Short one-line description of this product line goes here.',
        link: '/products/series-two'
    },
    {
        image: '/images/hero-3.jpg',
        title: 'Product Series Three',
        subtitle: 'Short one-line description of this product line goes here.',
        link: '/products/series-three'
    }
] %}

{% set quick_links = [
    { icon: '📖', label: 'Product Directory', url: '/products' },
    { icon: '🖇️', label: 'Marketing Support', url: '/support/marketing' },
    { icon: '📥', label: 'Catalog Download',  url: '/downloads/catalog' },
    { icon: '🏢', label: 'Showroom',           url: '/showroom' }
] %}

{% set value_prop = {
    image: '/images/value-banner.jpg',
    headline: 'We provide one-stop solutions for office, home and pro markets.',
    cta_label: 'Learn More',
    cta_url: '/about'
} %}

{% set articles = [
    { image: '/images/article-1.jpg', tag: 'Guide',   title: 'Buying Guide: Getting Started',      date: '2026-06-01', url: '/news/article-1' },
    { image: '/images/article-2.jpg', tag: 'Guide',   title: 'How To Choose The Right Setup',       date: '2026-05-20', url: '/news/article-2' },
    { image: '/images/article-3.jpg', tag: 'News',    title: 'Behind The Scenes: Product Design',   date: '2026-05-10', url: '/news/article-3' },
    { image: '/images/article-4.jpg', tag: 'Overview',title: 'A Look At Our Sourcing Process',      date: '2026-04-28', url: '/news/article-4' }
] %}

{% set why_choose = {
    heading: 'Why Choose Us',
    body: 'Describe your manufacturing/ODM/OEM capabilities, factory expertise, and the support services you offer partners here. Keep it to two or three short paragraphs.',
    cta_label: 'Contact Us',
    cta_url: '/contact'
} %}

{% set footer_columns = [
    { heading: 'About Us', links: [
        { label: 'Our Story', url: '/about' },
        { label: 'Careers', url: '/careers' },
        { label: 'Contact', url: '/contact' }
    ]},
    { heading: 'Products', links: [
        { label: 'All Products', url: '/products' },
        { label: 'New Arrivals', url: '/products/new' }
    ]},
    { heading: 'Support', links: [
        { label: 'Help Center', url: '/support' },
        { label: 'Warranty', url: '/support/warranty' }
    ]},
    { heading: 'News', links: [
        { label: 'Latest News', url: '/news' },
        { label: 'Press', url: '/news/press' }
    ]}
] %}

{% set social_links = [
    { label: 'Twitter',   url: '#' },
    { label: 'Facebook',  url: '#' },
    { label: 'LinkedIn',  url: '#' },
    { label: 'YouTube',   url: '#' },
    { label: 'Instagram', url: '#' }
] %}

{% set legal_links = [
    { label: 'Privacy Policy', url: '/privacy' },
    { label: 'Sitemap', url: '/sitemap' },
    { label: 'Contact', url: '/contact' }
] %}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ site.name }}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="stylesheet" href="/plugin-assets/PlentyTestPlugin/css/demo-home.css">
</head>
<body>

    <header class="site-header">
        <div class="wrap nav-bar">
            <div class="logo">{{ site.name }}<span>{{ site.tagline }}</span></div>
            <nav class="main-nav">
                <ul>
                    {% for item in nav_items %}
                        <li><a href="{{ item.url }}">{{ item.label }}</a></li>
                    {% endfor %}
                </ul>
            </nav>
        </div>
    </header>

    <section class="hero" id="hero">
        {% for slide in hero_slides %}
            <div class="hero-slide{% if loop.first %} active{% endif %}" data-bg="{{ slide.image }}" data-index="{{ loop.index0 }}">
                <div class="wrap hero-text">
                    <h2>{{ slide.title }}</h2>
                    <p>{{ slide.subtitle }}</p>
                    <a class="btn" href="{{ slide.link }}">Learn More</a>
                </div>
            </div>
        {% endfor %}
        <div class="hero-dots">
            {% for slide in hero_slides %}
                <button data-index="{{ loop.index0 }}"{% if loop.first %} class="active"{% endif %}></button>
            {% endfor %}
        </div>
    </section>

    <div class="quick-links">
        {% for link in quick_links %}
            <a href="{{ link.url }}"><span class="icon">{{ link.icon }}</span>{{ link.label }}</a>
        {% endfor %}
    </div>

    <section class="value-prop" data-bg="{{ value_prop.image }}">
        <div class="inner">
            <h2>{{ value_prop.headline }}</h2>
            <a class="btn" href="{{ value_prop.cta_url }}">{{ value_prop.cta_label }}</a>
        </div>
    </section>

    <section class="insights">
        <div class="wrap">
            <h2>Insights &amp; Guides</h2>
            <div class="articles-grid">
                {% for article in articles %}
                    <a class="article-card" href="{{ article.url }}">
                        <img src="{{ article.image }}" alt="{{ article.title }}">
                        <div class="article-body">
                            <div class="article-tag">{{ article.tag }}</div>
                            <div class="article-title">{{ article.title }}</div>
                            <div class="article-date">{{ article.date }}</div>
                        </div>
                    </a>
                {% endfor %}
            </div>
        </div>
    </section>

    <section class="why-choose">
        <div class="wrap">
            <h2>{{ why_choose.heading }}</h2>
            <p>{{ why_choose.body }}</p>
            <a class="btn" href="{{ why_choose.cta_url }}">{{ why_choose.cta_label }}</a>
        </div>
    </section>

    <footer class="site-footer">
        <div class="wrap">
            <div class="footer-columns">
                {% for column in footer_columns %}
                    <div>
                        <h3>{{ column.heading }}</h3>
                        <ul>
                            {% for link in column.links %}
                                <li><a href="{{ link.url }}">{{ link.label }}</a></li>
                            {% endfor %}
                        </ul>
                    </div>
                {% endfor %}
            </div>
            <div class="footer-bottom">
                <div>Copyright &copy; {{ "now"|date("Y") }} {{ site.name }}. All Rights Reserved.</div>
                <div class="footer-legal">
                    {% for link in legal_links %}
                        <a href="{{ link.url }}">{{ link.label }}</a>
                    {% endfor %}
                </div>
                <div class="footer-social">
                    {% for social in social_links %}
                        <a href="{{ social.url }}">{{ social.label }}</a>
                    {% endfor %}
                </div>
            </div>
        </div>
    </footer>

    <script src="/plugin-assets/PlentyTestPlugin/js/demo-home.js"></script>

</body>
</html>
